---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PageHero from '@/components/PageHero.astro';
import ContactForm from '@/components/ContactForm.astro';
import FAQ from '@/components/FAQ.astro';
import Icon from '@/components/Icon.astro';
import { contactFaqs } from '@/data/faqs';

const hours = [
  { day: "Monday – Friday", time: "7am – 6pm" },
  { day: "Saturday", time: "8am – 2pm" },
  { day: "Sunday", time: "Closed" },
]
---

<Layout
  title="Contact & Free Insulation Estimate"
  description="Get a free insulation estimate from A Plus Insulation. Call 850-555-0199 or send a message. Serving Panama City and the Florida Gulf Coast, Mon–Sat."
>
  <div class="min-h-screen bg-background">
    <Header />
    <main>
    <PageHero
      eyebrow="contact"
      title={'Get your <span class="text-primary">free estimate</span>'}
      description="Ready to lower your power bills? Tell us about your project and we'll get right back to you. Prefer to talk? Give us a call — we're always happy to help."
    />

    <section class="py-20 md:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
          {/* Info */}
          <div class="lg:col-span-2">
            <h2 class="font-heading uppercase text-2xl md:text-3xl text-foreground mb-6 text-balance leading-tight">
              Talk to A Plus Insulation
            </h2>

            <div class="space-y-5">
              <a
                href="tel:8505550199"
                class="flex items-start gap-4 group"
              >
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md bg-primary/15 group-hover:bg-primary transition-colors">
                  <Icon name="phone" class="h-5 w-5 text-primary group-hover:text-primary-foreground transition-colors" />
                </span>
                <span>
                  <span class="block text-xs uppercase tracking-wide text-muted-foreground">Call us</span>
                  <span class="font-heading text-xl text-foreground">850-555-0199</span>
                </span>
              </a>

              <a
                href="mailto:info@example.com"
                class="flex items-start gap-4 group"
              >
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md bg-primary/15 group-hover:bg-primary transition-colors">
                  <Icon name="mail" class="h-5 w-5 text-primary group-hover:text-primary-foreground transition-colors" />
                </span>
                <span>
                  <span class="block text-xs uppercase tracking-wide text-muted-foreground">Email us</span>
                  <span class="text-lg text-foreground">info@example.com</span>
                </span>
              </a>

              <div class="flex items-start gap-4">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md bg-primary/15">
                  <Icon name="map-pin" class="h-5 w-5 text-primary" />
                </span>
                <span>
                  <span class="block text-xs uppercase tracking-wide text-muted-foreground">Service area</span>
                  <span class="text-lg text-foreground">Gulf Coast &amp; Florida Panhandle</span>
                </span>
              </div>
            </div>

            {/* Hours */}
            <div class="mt-10 p-6 rounded-xl bg-card border border-border">
              <div class="flex items-center gap-2 mb-4">
                <Icon name="clock" class="h-4 w-4 text-primary" />
                <h3 class="font-heading uppercase tracking-wide text-base text-foreground">Business Hours</h3>
              </div>
              <ul class="space-y-3 text-sm">
                {hours.map((h) => (
                  <li class="flex justify-between gap-4">
                    <span class="text-muted-foreground">{h.day}</span>
                    <span class="text-foreground">{h.time}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          {/* Form */}
          <div class="lg:col-span-3">
            <ContactForm />
          </div>
        </div>
      </div>
    </section>

    <FAQ faqs={contactFaqs} heading="Free estimate FAQs" />
    </main>
    <Footer />
  </div>
</Layout>
