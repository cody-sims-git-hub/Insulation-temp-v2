---
import Icon from "@/components/Icon.astro";
import Button from "@/components/ui/Button.astro";

const services = [
  "Spray Foam",
  "Blown Fiberglass",
  "Mobile Home Insulation",
  "Wall Spray Cellulose",
  "Blown Cellulose",
  "Roll & Batt",
  "Garage Doors",
  "Other",
]
---

<div id="cf-success" class="hidden bg-card border border-border rounded-2xl p-8 text-center">
  <div class="w-14 h-14 mx-auto rounded-full bg-primary flex items-center justify-center mb-5">
    <Icon name="check" class="w-7 h-7 text-primary-foreground" />
  </div>
  <h3 class="font-heading uppercase text-2xl text-foreground mb-2">Message sent</h3>
  <p class="text-muted-foreground">
    Thanks for reaching out! A member of the A Plus Insulation team will get back to you shortly to schedule your
    free estimate.
  </p>
</div>

<form
  id="cf-form"
  class="bg-card border border-border rounded-2xl p-6 md:p-8 space-y-4"
>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label for="name" class="block text-sm font-medium text-foreground mb-1.5">
        Full name
      </label>
      <input
        id="name"
        type="text"
        required
        class="w-full rounded-md border border-input bg-background px-3 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
        placeholder="John Smith"
      />
    </div>
    <div>
      <label for="phone" class="block text-sm font-medium text-foreground mb-1.5">
        Phone
      </label>
      <input
        id="phone"
        type="tel"
        required
        class="w-full rounded-md border border-input bg-background px-3 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
        placeholder="(850) 000-0000"
      />
    </div>
  </div>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label for="email" class="block text-sm font-medium text-foreground mb-1.5">
        Email
      </label>
      <input
        id="email"
        type="email"
        class="w-full rounded-md border border-input bg-background px-3 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
        placeholder="you@example.com"
      />
    </div>
    <div>
      <label for="service" class="block text-sm font-medium text-foreground mb-1.5">
        Service needed
      </label>
      <select
        id="service"
        class="w-full rounded-md border border-input bg-background px-3 py-2.5 text-foreground focus:outline-none focus:ring-2 focus:ring-ring"
      >
        {services.map((service) => (
          <option>{service}</option>
        ))}
      </select>
    </div>
  </div>
  <div>
    <label for="details" class="block text-sm font-medium text-foreground mb-1.5">
      How can we help?
    </label>
    <textarea
      id="details"
      rows={4}
      class="w-full rounded-md border border-input bg-background px-3 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring resize-none"
      placeholder="Tell us about your home and project..."
    ></textarea>
  </div>
  <Button
    type="submit"
    size="lg"
    class="w-full bg-primary hover:bg-primary/90 text-primary-foreground rounded-md py-6 font-semibold uppercase tracking-wide"
  >
    Send Message
  </Button>
  <p class="text-xs text-muted-foreground text-center">
    No cost, no obligation. We&apos;ll never share your information.
  </p>
</form>

<script>
  const form = document.getElementById('cf-form');
  const success = document.getElementById('cf-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
